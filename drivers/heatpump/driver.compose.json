{
  "name": {
    "en": "Nibe Heat Pump",
    "sv": "Nibe Värmepump"
  },
  "class": "heatpump",
  "capabilities": [
    "measure_temperature",
    "target_temperature",
    "operating_priority",
    "compressor_frequency",
    "measure_temperature.supply",
    "measure_temperature.return",
    "measure_temperature.calculated_supply",
    "measure_temperature.outdoor",
    "pump_speed",
    "airflow",
    "measure_temperature.hotwater",
    "hotwater_amount",
    "measure_power",
    "meter_power",
    "additional_heat_power",
    "add_heat_time_heating",
    "ventilation_boost",
    "ventilation_mode",
    "add_heat_time_hotwater",
    "hot_water_boost"
  ],
  "capabilitiesOptions": {
    "measure_temperature": {
      "title": { "en": "Indoor", "sv": "Inomhus" }
    },
    "measure_temperature.outdoor": {
      "title": { "en": "Outdoor", "sv": "Utomhus" }
    },
    "measure_temperature.hotwater": {
      "title": { "en": "Hot water", "sv": "Varmvatten" }
    },
    "measure_temperature.supply": {
      "title": { "en": "Supply", "sv": "Framledning" }
    },
    "measure_temperature.return": {
      "title": { "en": "Return", "sv": "Returledning" }
    },
    "measure_temperature.calculated_supply": {
      "title": { "en": "Calculated supply", "sv": "Beräknad framledning" }
    },
    "meter_power": {
      "title": { "en": "Consumption", "sv": "Förbrukning" },
      "decimals": 3
    },
    "target_temperature": {
      "title": { "en": "Indoor", "sv": "Måltemperatur" },
      "min": 5,
      "max": 35,
      "step": 0.5,
      "units": { "en": "°C" }
    }
  },
  "images": {
    "small": "/drivers/heatpump/assets/images/small.png",
    "large": "/drivers/heatpump/assets/images/large.png",
    "xlarge": "/drivers/heatpump/assets/images/xlarge.png"
  },
  "platforms": ["local"],
  "connectivity": ["cloud"],
  "pair": [
    {
      "id": "login_oauth2",
      "template": "login_oauth2"
    },
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": { "next": "add_devices" }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
  "repair": [
    {
      "id": "login_oauth2",
      "template": "login_oauth2"
    }
  ]
}
